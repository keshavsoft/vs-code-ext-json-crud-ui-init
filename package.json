{
  "name": "vs-code-ext-json-crud-ui-init",
  "displayName": "crud ui init",
  "description": "Generate Ui for Json Crud",
  "publisher": "KeshavSoft",
  "type": "module",
  "version": "1.4.2",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/keshavsoft/vs-code-ext-json-crud-ui-init.git"
  },
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.editor.title.folder.ui.init",
        "title": "Ui Init"
      },
      {
        "command": "extension.explorer.right.public.init",
        "title": "InitFromScript"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "extension.editor.title.folder.ui.init",
          "when1": "explorerResourceIsFolder",
          "when": "explorerResourceIsFolder && resourceFilename == Public",
          "group": "navigation@2"
        },
        {
          "command": "extension.explorer.right.public.init",
          "when": "explorerResourceIsFolder && resourceFilename == Public",
          "group": "navigation@2"
        }
      ],
      "editor/context": [],
      "editor/title": []
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "json-crud-ui-init": "^1.7.3"
  }
}
